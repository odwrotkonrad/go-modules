{
  "$defs": {
    "destEntry": {
      "oneOf": [
        {
          "description": "dest path: relative -\u003e repo, ~/ or absolute -\u003e host",
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "options": {
              "additionalProperties": false,
              "description": "per-dest render options",
              "properties": {
                "renderReferencedFiles": {
                  "description": "inline @-includes into the rendered body (overwrite only)",
                  "type": "boolean"
                },
                "writeType": {
                  "description": "how the rendered body lands: overwrite (default: header + body) | mergeUpsert (env KEY=VALUE union under the existing dest) | raw (body verbatim, no autogen header)",
                  "enum": [
                    "",
                    "mergeUpsert",
                    "raw"
                  ]
                }
              },
              "type": "object"
            },
            "path": {
              "description": "dest path: relative -\u003e repo, ~/ or absolute -\u003e host",
              "type": "string"
            }
          },
          "required": [
            "path"
          ],
          "type": "object"
        }
      ]
    },
    "dirEntry": {
      "oneOf": [
        {
          "description": "dir path (brace-expanded)",
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "dest": {
              "description": "dir paths (brace-expanded)",
              "items": {
                "$ref": "#/$defs/destEntry"
              },
              "type": "array"
            }
          },
          "required": [
            "dest"
          ],
          "type": "object"
        }
      ]
    },
    "excludeSet": {
      "additionalProperties": false,
      "description": "subtractive glob filter, applied last, wins over every include (rich entries too)",
      "properties": {
        "copy": {
          "description": "drop matching copy items (source or dest)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "link": {
          "description": "drop matching link items",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "mkdirs": {
          "description": "drop matching dirs",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "renderTemplates": {
          "description": "drop matching template items (source or dest)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "runScripts": {
          "description": "drop matching scripts (resolved file paths)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "services": {
          "description": "drop matching services",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "fileEntry": {
      "oneOf": [
        {
          "description": "glob over git-tracked files (brace-expanded)",
          "type": "string"
        },
        {
          "additionalProperties": false,
          "description": "one source fanned out to explicit dests",
          "properties": {
            "dest": {
              "description": "dest paths: relative -\u003e repo, ~/ or absolute -\u003e host; omitted -\u003e derived from the root/ source path",
              "items": {
                "$ref": "#/$defs/destEntry"
              },
              "type": "array"
            },
            "source": {
              "description": "repo-relative source path",
              "type": "string"
            }
          },
          "required": [
            "source"
          ],
          "type": "object"
        }
      ]
    },
    "includeSet": {
      "additionalProperties": false,
      "description": "additive payload: link globs, copy/renderTemplates/mkdirs perm-groups, script globs, service names",
      "properties": {
        "copy": {
          "description": "*.ontoHost.cp copy-op perm-groups",
          "items": {
            "additionalProperties": false,
            "properties": {
              "chmod": {
                "description": "dest mode, octal string",
                "pattern": "^[0-7]{3,4}$",
                "type": "string"
              },
              "files": {
                "description": "the group's items, each inheriting the group's perms",
                "items": {
                  "$ref": "#/$defs/fileEntry"
                },
                "type": "array"
              },
              "owner": {
                "description": "dest owner user; empty: code default",
                "type": "string"
              },
              "ownerGroup": {
                "description": "dest owner group; empty: code default",
                "type": "string"
              }
            },
            "required": [
              "files"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "link": {
          "description": "symlink-op globs, repo-relative under root/",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "mkdirs": {
          "description": "extra-dir perm-groups; each item one dir path (brace-expanded)",
          "items": {
            "additionalProperties": false,
            "properties": {
              "chmod": {
                "description": "dest mode, octal string",
                "pattern": "^[0-7]{3,4}$",
                "type": "string"
              },
              "files": {
                "description": "the group's items, each inheriting the group's perms",
                "items": {
                  "$ref": "#/$defs/dirEntry"
                },
                "type": "array"
              },
              "owner": {
                "description": "dest owner user; empty: code default",
                "type": "string"
              },
              "ownerGroup": {
                "description": "dest owner group; empty: code default",
                "type": "string"
              }
            },
            "required": [
              "files"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "renderTemplates": {
          "description": "*.tpl render-op perm-groups; sources repo-root-relative, glob and derived-dest forms must be root/-prefixed",
          "items": {
            "additionalProperties": false,
            "properties": {
              "chmod": {
                "description": "dest mode, octal string",
                "pattern": "^[0-7]{3,4}$",
                "type": "string"
              },
              "files": {
                "description": "the group's items, each inheriting the group's perms",
                "items": {
                  "$ref": "#/$defs/fileEntry"
                },
                "type": "array"
              },
              "owner": {
                "description": "dest owner user; empty: code default",
                "type": "string"
              },
              "ownerGroup": {
                "description": "dest owner group; empty: code default",
                "type": "string"
              }
            },
            "required": [
              "files"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "runScripts": {
          "description": "script paths or globs, repo-relative, run in spec order",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "services": {
          "description": "launchd service names",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "pluginEntry": {
      "oneOf": [
        {
          "description": "`@\u003cgiturl\u003e::\u003cprofile\u003e` (remote) or `\u003cdir\u003e::\u003cprofile\u003e` (local dir) plugin ref",
          "pattern": "^.+::.+$",
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "env": {
              "additionalProperties": {
                "type": "string"
              },
              "description": "envs exported around everything done for the plugin's unit",
              "type": "object"
            },
            "ref": {
              "description": "`@\u003cgiturl\u003e::\u003cprofile\u003e` (remote) or `\u003cdir\u003e::\u003cprofile\u003e` (local dir) plugin ref",
              "pattern": "^.+::.+$",
              "type": "string"
            }
          },
          "required": [
            "ref"
          ],
          "type": "object"
        }
      ]
    },
    "profile": {
      "additionalProperties": false,
      "description": "one profile block: options self-describe eligibility, mixinProfiles compose in order, plugins pull remote profiles, include adds, exclude filters last and wins",
      "properties": {
        "exclude": {
          "$ref": "#/$defs/excludeSet"
        },
        "include": {
          "$ref": "#/$defs/includeSet"
        },
        "mixinProfiles": {
          "description": "local profile names composed depth-first, in order",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "options": {
          "additionalProperties": false,
          "description": "when the profile runs: autoExec opts in to bare-che runs, execIf predicates must ALL pass",
          "properties": {
            "autoExec": {
              "description": "run on bare che (default false: runs only via --profile or mixinProfiles)",
              "type": "boolean"
            },
            "execIf": {
              "description": "predicate expressions `\u003csource\u003e` or `\u003csource\u003e == \u003cliteral\u003e`, sources builtin:*/env:*; empty: always",
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "plugins": {
          "description": "profiles loaded at their own checkout: `@\u003cgiturl\u003e::\u003cprofile\u003e` (remote) or `\u003cdir\u003e::\u003cprofile\u003e` (local dir) string, or {ref, env}",
          "items": {
            "$ref": "#/$defs/pluginEntry"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  },
  "$id": "https://gitlab.com/konradodwrot/go-modules/-/raw/main/che/assets/data/che.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": {
    "$ref": "#/$defs/profile"
  },
  "description": "che spec: every top-level key defines a profile block",
  "title": "che.yml",
  "type": "object"
}
